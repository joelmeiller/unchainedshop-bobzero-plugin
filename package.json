  "types": "lib/plugin.d.ts",
  "exports": {
    ".": "./lib/plugin.js",
    "./*": "./lib/*"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf lib",
    "build": "npm run clean && tsc",
