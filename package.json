  "homepage": "https://github.com/unchainedshop/unchained#readme",
  "devDependencies": {
    "@types/node": "^18.13.0",
    "@unchainedshop/core-payment": "^2.0.6",
    "@unchainedshop/logger": "^2.0.6",
    "@unchainedshop/types": "^2.0.6",
    "@unchainedshop/utils": "^2.0.6",
    "mongodb": "^4.14.0",
    "prettier": "^2.8.4",
    "request": "^2.88.2",
    "typescript": "^4.9.5"
  },
